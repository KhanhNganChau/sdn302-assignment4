{
  "$schema": "https://turbo.build/schema.json",

  "globalDependencies": [".env*"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_URL"]
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_API_URL"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
